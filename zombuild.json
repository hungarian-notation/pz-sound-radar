{
    "$schema": "./zombuild.schema.json",

    "id": "hfsound",
    "name": "Sound Radar",
    "version": "0.0.1",
    "description": { "ref": "src/hfsound/mod-description.txt" },
    "url": "https://example.com",

    "preview": "src/hfsound/assets/preview.png",

    "authors": [ "hafnium" ],
    "category": "features",
    "versionMin": "42.0",
    "require": [ ],
    "incompatible": [ ],

    "output": ".dist",

    "mods": {
        "hfsound": {

            "name": "Sound Radar",
            "poster": "src/hfsound/assets/poster.png",
            "icon": "src/hfsound/assets/icon.png",
            "versionMin": "42.15",
            "versions": {
                "common": [
                    {
                        "source": "src/hfsound/assets/textures",
                        "prefix": "media/textures/hfsound"
                    },
                    {
                        "source": ".generated/assets/textures",
                        "prefix": "media/textures/hfsound"
                    }
                ],

                "42.16": [
                    {
                        "source": "src/hfsound/main/media/lua",
                        "prefix": "media/lua",
                        "ignore": "*.d.lua"
                    },
                    {
                        "source": ".generated/lua",
                        "prefix": "media/lua/shared",
                        "ignore": "*.d.lua"
                    },
                    {
                        "action": "translations",
                        "target": [
                            {
                                "source": "src/hfsound/main/translations",
                                "prefix": "media/lua/shared/Translate",
                                "glob": "*.json"
                            }
                        ]
                    }
                ]
            }
        }
    },

    "plugins": [ "core", "codegen", "hfsound" ],

    "tasks": {
        "gradients": {
            "type": "hfsound.GradientsTask",
            "output": ".generated/assets/textures/gradient",
            "width": 1024, "height": 256
        },
        "enums": {
            "type": "codegen.EnumsTask",
            "enums": [
                {
                    "type": "hfs.Gradient",
                    "glob": ".generated/assets/textures/gradient/*.png",
                    "output": ".generated/lua/hfsound/gradients.lua"
                },
                {
                    "type": "hfs.Icon",
                    "glob": "src/hfsound/assets/textures/icon/*.png",
                    "output": ".generated/lua/hfsound/icons.lua"
                }
            ]
        }
    }
}