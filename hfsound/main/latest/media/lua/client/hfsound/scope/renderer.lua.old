local geomlib = require('hfsound/geom')
local rotateVector = geomlib.rotate_vector
local project_isometric = geomlib.project_isometric
local project_isometricoff = geomlib.project_isometricoff

local hf_graphics = require('hfsound/graphics')
local drawTextureIsometric = hf_graphics.drawTextureIsometric
local drawTexture = hf_graphics.drawTexture

local PI = 3.141592653589793

